"gqsingle_shifter_M": {
    "information":{
        "authors":"BeamNG",
        "name":"5 Speed Manual Shifter",
        "value":50,
    },
    "slotType" : "gqsingle_shifter",
    "flexbodies": [
         ["mesh", "[group]:", "nonFlexMaterials"],
         //cover up the auto shifter numbering
         ["", ["pickup_body", "pickup_dash"]],
         ["gqsingle_shifter_M", ["pickup_floor","pickup_shifterboot_M","pickup_shifterknob_M","pickup_shifterbase_M"]],
    ],
    "controller": [
        ["fileName"],
        ["propAnimation/hPattern", {"name":"hPattern"}],

    ]
    "hPattern": {
        "gearCoordinates": [
            ["gearIndex",   "x",      "y"]
            [-1,            0.5,       -1]
            [0,             0.0,        0]
            [1,            -0.5,        1]
            [2,            -0.5,       -1]
            [3,             0.0,        1]
            [4,             0.0,       -1]
            [5,             0.5,        1]
        ]
        "shiftSoundNode:":["sh_b3"]
        "shiftSoundEventHPatternGearIn": "event:>Vehicle>Interior>Gearshift>manual_modern_03_in",
        "shiftSoundEventHPatternGearOut": "event:>Vehicle>Interior>Gearshift>manual_modern_03_out",
        "shiftSoundVolumeHPatternGearIn": 1,
        "shiftSoundVolumeHPatternGearOut": 1,
    },
    "props": [
        ["func",   "mesh",             "idRef:","idX:","idY:", "baseRotation",         "rotation",            "translation",         "min", "max", "offset", "multiplier"],
        //shifter
        ["clutch", ""   , "b1l","b1r","b5l",    {"x":0, "y":0, "z":180}, {"x":-25, "y":0, "z":0}    , {"x":0.0, "y":0, "z":0}, 0, 1, 0, 1]
    ],
    "nodes": [
         ["id", "posX", "posY", "posZ"],
         {"frictionCoef":0.5},
         {"nodeMaterial":"|NM_METAL"},
         {"collision":true},
         {"selfCollision":false},
         //--SHIFTER---  has to be jbeamed to allow for realistic movement
         {"group":"pickup_shifterbase_M"},
         {"nodeWeight":0.45}
         ["sh_b1l", -0.04109, -0.40383, 0.70098],
         ["sh_b1r", -0.14167, -0.35568, 0.67805],
         ["sh_b2l", -0.04109, -0.31436, 0.66722],
         ["sh_b2r", -0.14167, -0.31436, 0.66722],

         ["sh_b3", -0.10427, -0.40379, 0.68419],
         {"selfCollision":true},
         {"group":["pickup_shifterboot_M","pickup_shifterknob_M"]},
         {"nodeWeight":1.5}
         ["sh_l3", -0.10641, -0.19235, 1.00160],

         {"selfCollision":false},
         {"nodeWeight":0.30}
         {"group":["pickup_shifterboot_M","pickup_shifterknob_M"]},
         ["sh_l1l", -0.06489, -0.34257, 0.81590],
         ["sh_l1r", -0.12289, -0.34257, 0.81590],
         ["sh_l2l", -0.06489, -0.28404, 0.78547],
         ["sh_l2r", -0.12289, -0.28404, 0.78547],
         {"selfCollision":false},
         {"collision":true},
         {"group":""},
    ],
    "beams":[
        ["id1:", "id2:"],
        {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1.0, "beamShortBound":1.0},
        //main shape
        {"beamSpring":401000,"beamDamp":55},
        {"beamDeform":259000,"beamStrength":"FLT_MAX"},
        {"deformLimitExpansion":1.1},
        ["sh_b1l", "sh_b1r"],
        ["sh_b1l", "sh_b2l"],
        ["sh_b1l", "sh_b2r"],
        ["sh_b1r", "sh_b2l"],
        ["sh_b1r", "sh_b2r"],
        ["sh_b2l", "sh_b2r"],

        ["sh_b1l", "sh_b3"],
        ["sh_b1r", "sh_b3"],
        ["sh_b2l", "sh_b3"],
        ["sh_b2r", "sh_b3"],

        //lever
        {"beamSpring":121000,"beamDamp":35},
        ["sh_l3", "sh_l1l"],
        ["sh_l3", "sh_l1r"],
        ["sh_l3", "sh_l2l"],
        ["sh_l3", "sh_l2r"],

