         {"nodeWeight":1.88},
         {"group":["pickup_windshield","gps"]},
         ["wi1", 0.00000, -0.65484, 1.46858],
         {"group":""},
         {"nodeMaterial":"|NM_METAL"},

         //add weight

         //roof
         {"group":"pickup_body"},
         {"nodeWeight":3.008},
         ["rf1r", -0.58560, -0.38148, 1.71162, {"group":["pickup_body","pickup_windshield","gps"]}],
         ["rf1", 0.00000, -0.41544, 1.71720, {"group":["pickup_body","pickup_windshield","gps"]}],
         ["rf1l", 0.58560, -0.38148, 1.71162, {"group":["pickup_body","pickup_windshield","gps"]}],

         //a-pillar
         {"nodeWeight":2.256},
         ["p1r", -0.54656, -0.60593, 1.48040, {"group":["pickup_body","pickup_windshield","gps"]}],
         ["p1l", 0.54656, -0.51556, 1.42158, {"group":["pickup_body","pickup_windshield","gps"]}],
         ["p2r", -0.62629, -0.61560, 1.44179, {"group":["pickup_body","pickup_windshield","gps"]}],
         ["p2l", 0.59598, -0.56358, 1.53882, {"group":["pickup_body","pickup_windshield","gps"]}],

         //firewall
         {"nodeWeight":5.828},
         ["b6rr", -0.70368, -0.77934, 1.24354, {"group":["pickup_body","pickup_windshield","gps","pickup_snorkel"]}],
         ["b6r", -0.30365, -0.81138, 1.29154, {"group":["pickup_body","pickup_windshield","gps"]}],
         ["b6l", 0.30365, -0.81330, 1.29682, {"group":["pickup_body","pickup_windshield","gps"]}],
         ["b6ll", 0.69582, -0.77934, 1.25212, {"group":["pickup_body","pickup_windshield","gps"]}],
         {"group":""},
    ],
    "beams": [
          ["id1:", "id2:"],
          {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1.0, "beamShortBound":1.0},
          {"beamSpring":1895830,"beamDamp":244.4},
          {"disableMeshBreaking":true,"disableTriangleBreaking":true},
          {"deformGroup":"windshield_break", "deformationTriggerRatio":0.03},
          {"beamDeform":7000,"beamStrength":"FLT_MAX"},
          //windshield
          {"deformLimitExpansion":""},
          ["wi1","rf1"],
          ["p1r","wi1"],
          ["p1l","wi1"],
          ["wi1","b6r"],
          ["wi1","b6l"],
          ["wi1","rf2"],
          ["rf1r","wi1"],
          ["rf1l","wi1"],

          ["wi1","b6rr"],
          ["wi1","b6ll"],

          {"beamDeform":7000,"beamStrength":14952},
          ["p1r","p1l"],
          ["rf1r","b6r"],
          ["rf1l","b6l"],

          ["rf1","b6r"],
          ["rf1","b6l"],
          {"breakGroup":""},
          {"disableMeshBreaking":false,"disableTriangleBreaking":false},
          {"deformGroup":""},
          {"deformLimitExpansion":1.2},
    ],
    "mirrors": [
        ["name", "id1:", "id2:", "id3:", "textureTarget"],
        ["mirror_M", "p2ll", "p2rr", "rf1r", "@mirror_M"]
    ],
},
