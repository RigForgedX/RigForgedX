{
"gqsingle_windshield": {
    "information":{
        "authors":"TAXI_DRIVER",
        "name":"Windshield",
        "value":350,
    },
    "slotType" : "gqsingle_windshield",
    "flexbodies": [
         ["mesh", "[group]:", "nonFlexMaterials"],
         //glass
         ["gqsingle_windscreen", ["pickup_windshield"],[]{"deformSound":"event:>Destruction>Vehicle>Glass>impact_glass_windscreen_01", "deformVolume":0.7}],
